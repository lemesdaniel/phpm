{
  "name": "acme/app",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^11.0",
    "monolog/monolog": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": ["database/factories/", "extra/factories/"]
    },
    "files": ["app/helpers.php"],
    "classmap": ["app/Legacy"]
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ]
  },
  "bin": ["bin/console"]
}
